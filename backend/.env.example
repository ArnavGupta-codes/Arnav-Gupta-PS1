# FocusFlow Backend Configuration

# Put your Google Gemini API Key here to enable true AI-generated standups.
# If left blank, the backend will gracefully fall back to a structured template format.
GEMINI_API_KEY=your_gemini_api_key_here

# JWT Secret for signing tokens (Use a strong random string in production)
JWT_SECRET=your_jwt_secret_key_here

# Allowed origins for CORS (comma separated)
ALLOWED_ORIGINS=http://localhost:3000
